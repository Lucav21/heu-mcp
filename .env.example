# HEU Legal API credentials
# Ottieni una API key da: Profile > API Keys > Generate API Key
# (Richiede subscription Enterprise)

HEU_API_KEY=your_api_key_here

# Base URL (default: produzione)
HEU_BASE_URL=https://api.heulegal.com/v1

# Cartella dove salvare i PDF scaricati (default: /tmp)
HEU_DOWNLOAD_DIR=/tmp
